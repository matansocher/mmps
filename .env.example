# ============================================================================
# MMPS environment variables
# Copy to .env and fill in. Only the vars for the bots/tools you actually
# exercise locally are required — see AGENTS.md → "Environment Variables".
# ============================================================================

# ----- Runtime -----
PORT=3000
NODE_ENV=development
# Set IS_PROD=true to boot all 5 bots; leave false locally and use LOCAL_ACTIVE_BOT_ID.
IS_PROD=false
# Public URL the app reports about itself (used by mini-apps / oauth callbacks).
MMPS_BASE_URL=https://mmps-a9baabab2459.herokuapp.com

# Which bot to run locally. UPPERCASE id: CHATBOT | CHILLI | COACH | WOLT | WORLDLY
LOCAL_ACTIVE_BOT_ID=CHATBOT


# ----- MongoDB -----
# Main connection string read by src/core/mongo/mongo-connection.ts.
MONGO_DB_URL=mongodb://localhost:27017
# Legacy var still read by a few standalone scripts under src/**/scripts/.
# Usually points at the same cluster as MONGO_DB_URL.
MONGO_URI=mongodb://localhost:27017

REDIS_URL=redis://localhost:6379


# ----- LLM providers (at least one) -----
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...


# ----- Telegram bot tokens (per bot) -----
CHATBOT_TELEGRAM_BOT_TOKEN=
CHILLI_TELEGRAM_BOT_TOKEN=
COACH_TELEGRAM_BOT_TOKEN=
WOLT_TELEGRAM_BOT_TOKEN=
WORLDLY_TELEGRAM_BOT_TOKEN=
# Cross-bot notification utility (src/services/notifier)
NOTIFIER_TELEGRAM_BOT_TOKEN=
# Playground/test bot
PLAYGROUNDS_TELEGRAM_BOT_TOKEN=

# Telegram MTProto client (user-mode, not bot) for src/services/telegram-client
TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_STRING_SESSION=

# Telegram-login OIDC for the companion browser extension (src/shared/auth)
TELEGRAM_LOGIN_CLIENT_ID=
TELEGRAM_LOGIN_CLIENT_SECRET=
COMPANION_ORIGIN=chrome-extension://<your-extension-id>


# ----- Mini-app URLs (per bot) -----
COACH_MINI_APP_URL=
WOLT_MINI_APP_URL=
WORLDLY_MINI_APP_URL=
CHATBOT_MINI_APP_URL=
# Worldly dev-only user id (escape hatch for testing)
WORLDLY_DEV_USER_ID=
# Dev-only user id (escape hatch for testing the chatbot mini-app locally in a browser).
# Also overridable per-request via the X-Chatbot-Dev-User header.
DEV_USER_ID=


# ----- Chatbot tuning -----
# Optional: cap the LangGraph thread history per user (default in code).
CHATBOT_MAX_THREAD_MESSAGES=


# ----- Weather -----
WEATHERAPI_KEY=
OPENWEATHER_API_KEY=


# ----- Google services -----
# Calendar (service account)
GOOGLE_CALENDAR_CLIENT_EMAIL=
GOOGLE_CALENDAR_PRIVATE_KEY=
# Maps + Places
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_API_KEY=
# YouTube Data API v3
YOUTUBE_API_KEY=
# Sheets (logs in prod)
SHEETS_CLIENT_EMAIL=
SHEETS_PRIVATE_KEY=
SHEETS_LOGS_SPREADSHEET_ID=


# ----- GitHub App (for the github tool + claude.yml workflow integration) -----
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=


# ----- Sports / finance / markets -----
ALPHA_VANTAGE_API_KEY=
PINECONE_API_KEY=


# ----- Media -----
IMGUR_CLIENT_ID=
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REFRESH_TOKEN=

# YouTube transcripts (Supadata fallback when youtube-transcript fails)
SUPADATA_API_KEY=


# ----- Twitter (v2 API) -----
TWITTER_BEARER_TOKEN=


# ----- Twilio (SMS/voice) -----
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
MY_PHONE_NUMBER=


# ----- RapidAPI (TikTok + generic) -----
RAPIDAPI_KEY=
RAPIDAPI_TIKTOK_KEY=


# ----- Misc -----
# Public-facing tunnel for webhooks during local dev (e.g. ngrok)
WEBHOOK_PROXY_URL=

# ----- Apple Pay / iPhone Shortcut ingest -----
# Bearer token required on POST /api/chatbot/expenses for shortcut-based ingest
EXPENSES_INGEST_TOKEN=
