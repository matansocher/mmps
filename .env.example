# Application Mode
IS_PROD=false

# MongoDB Configuration
MONGO_URI=mongodb://localhost:27017

# AI APIs - Choose at least one
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# Bot Tokens - Add tokens for bots you want to run
CHATBOT_TELEGRAM_BOT_TOKEN=your-token-here
COACH_TELEGRAM_BOT_TOKEN=your-token-here
LANGLY_TELEGRAM_BOT_TOKEN=your-token-here
MAGISTER_TELEGRAM_BOT_TOKEN=your-token-here
WOLT_TELEGRAM_BOT_TOKEN=your-token-here
WORLDLY_TELEGRAM_BOT_TOKEN=your-token-here

# Development: Specify which bot to run (leave empty for all in production)
LOCAL_ACTIVE_BOT_ID=chatbot

# External Service Keys (Optional - add only if using these features)
GITHUB_TOKEN=ghp_...
GITHUB_APP_ID=your-app-id
GITHUB_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
GITHUB_APP_INSTALLATION_ID=your-installation-id
WEATHERAPI_KEY=...
SCORES_365_API_KEY=...

# Google Sheets Logging (Production only)
# These are required only if you want to log to Google Sheets in production
SHEETS_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
SHEETS_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n
SHEETS_LOGS_SPREADSHEET_ID=your-spreadsheet-id

# Telegram Login (OIDC) - For companion app authentication
TELEGRAM_LOGIN_CLIENT_ID=your-client-id-from-botfather
TELEGRAM_LOGIN_CLIENT_SECRET=your-client-secret-from-botfather
COMPANION_ORIGIN=chrome-extension://your-extension-id

# Optional: Port Configuration
# PORT=3000

# Optional: Database-specific names (auto-generated per bot)
# CHATBOT_DB_NAME=chatbot-db
# COACH_DB_NAME=coach-db
