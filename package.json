{
  "name": "mmps",
  "version": "1.0.0",
  "description": "Express TypeScript application",
  "main": "dist/index.js",
  "workspaces": [
    "apps/*"
  ],
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/matansocher/mmps.git"
  },
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "build": "tsc && tsc-alias --resolve-full-paths && npm run build:web-apps",
    "build:coach-web": "npm run build --workspace=@mmps/coach-web",
    "build:chatbot-web": "npm run build --workspace=@mmps/chatbot-web",
    "build:expenses-web": "npm run build --workspace=@mmps/expenses-web",
    "build:web-apps": "npm run build:coach-web && npm run build:chatbot-web && npm run build:expenses-web",
    "dev:coach-web": "npm run dev --workspace=@mmps/coach-web",
    "dev:chatbot-web": "npm run dev --workspace=@mmps/chatbot-web",
    "dev:expenses-web": "npm run dev --workspace=@mmps/expenses-web",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "dev:build": "tsc --watch",
    "dev:debug": "tsx watch --inspect src/index.ts",
    "debug": "node --inspect dist/index.js",
    "seed:expenses": "tsx scripts/seed-mock-data.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:draft": "tsx src/features/secretary/scripts/test-draft.ts",
    "eval:build": "tsx src/features/secretary/scripts/eval/build-dataset.ts",
    "eval:draft": "tsx src/features/secretary/scripts/eval/eval-prompt.ts",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "prepare": "husky",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "express",
    "typescript",
    "node"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@google-cloud/local-auth": "^3.0.1",
    "@grammyjs/hydrate": "^1.6.0",
    "@langchain/anthropic": "^1.4.0",
    "@langchain/core": "^1.1.48",
    "@langchain/langgraph": "^1.3.6",
    "@langchain/openai": "^1.4.7",
    "@octokit/app": "^16.1.2",
    "@octokit/auth-app": "^8.2.0",
    "@octokit/rest": "^22.0.1",
    "@pinecone-database/pinecone": "^6.1.3",
    "@turf/boolean-point-in-polygon": "^7.3.4",
    "@turf/helpers": "^7.3.4",
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.16.1",
    "bullmq": "^5.77.4",
    "canvas": "^3.2.0",
    "cheerio": "^1.1.2",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "dotenv": "^17.2.3",
    "express": "^5.1.0",
    "fluent-ffmpeg": "^2.1.3",
    "googleapis": "^169.0.0",
    "grammy": "^1.44.0",
    "input": "^1.0.1",
    "ioredis": "^5.11.0",
    "jose": "^6.2.2",
    "langchain": "^1.4.4",
    "mongodb": "^7.1.0",
    "node-cron": "^4.2.1",
    "openai": "^6.18.0",
    "pdf-parse": "^2.4.5",
    "picocolors": "^1.1.1",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "telegram": "^2.26.22",
    "twilio": "^5.10.7",
    "vitepress": "^1.6.4",
    "vue": "^3.5.28",
    "xlsx": "^0.18.5",
    "yahoo-finance2": "^3.10.2",
    "youtube-transcript": "^1.2.1",
    "youtube-transcript-plus": "^1.1.1",
    "youtubei.js": "^16.0.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.1.0",
    "@commitlint/config-conventional": "^20.0.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.2",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@trivago/prettier-plugin-sort-imports": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.5",
    "@types/fluent-ffmpeg": "^2.1.28",
    "@types/node": "^24.10.1",
    "@types/pdf-parse": "^1.1.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/eslint-plugin": "^8.48.0",
    "@typescript-eslint/parser": "^8.48.0",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "prettier": "^3.6.2",
    "semantic-release": "^25.0.2",
    "testcontainers": "^12.0.0",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "4.1.7"
  }
}
